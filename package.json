{
  "name": "top-app-v2",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "verify:nonprofit-canonical-names": "pnpm --dir web run verify:nonprofit-canonical-names",
    "seed:sponsors": "pnpm --dir web run seed:sponsors",
    "enrich:sponsors": "pnpm --dir web run enrich:sponsors",
    "sync:podcast-youtube": "pnpm --dir web run sync:podcast-youtube",
    "verify:platform-names": "pnpm --dir web run verify:platform-names",
    "repair:trusted-display-names": "pnpm --dir web run repair:trusted-display-names",
    "vercel": "vercel",
    "deploy:prod": "vercel --prod",
    "mobile:prep:prod": "pnpm --dir web run mobile:prep:prod",
    "mobile:prep:qa": "pnpm --dir web run mobile:prep:qa",
    "mobile:sync": "pnpm --dir web run cap:sync",
    "mobile:store:prep": "pnpm --dir web run mobile:store:prep",
    "mobile:android:bundle": "pnpm --dir web run mobile:android:bundle",
    "validate:capacitor": "pnpm --dir web run validate:capacitor"
  },
  "devDependencies": {
    "vercel": "^51.7.0"
  }
}
