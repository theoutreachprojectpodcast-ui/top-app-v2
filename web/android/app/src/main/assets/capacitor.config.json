{
	"appId": "com.theoutreachproject.theoutreachproject",
	"appName": "The Outreach Project",
	"webDir": "capacitor-www",
	"android": {
		"allowMixedContent": false,
		"androidScheme": "https"
	},
	"ios": {
		"contentInset": "never",
		"preferredContentMode": "mobile",
		"limitsNavigationsToAppBoundDomains": false
	},
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": false,
			"launchShowDuration": 0,
			"showSpinner": true,
			"iosSpinnerStyle": "large",
			"androidSpinnerStyle": "large",
			"spinnerColor": "#22a52b",
			"backgroundColor": "#121212"
		}
	},
	"server": {
		"url": "https://theoutreachproject.app",
		"cleartext": false,
		"errorPath": "error.html",
		"appendUserAgent": "TheOutreachProject/Capacitor",
		"allowNavigation": [
			"theoutreachproject.app",
			"*.theoutreachproject.app",
			"workos.com",
			"*.workos.com",
			"authkit.app",
			"*.authkit.app",
			"cloudflare.com",
			"*.cloudflare.com",
			"challenges.cloudflare.com",
			"turnstile.com",
			"*.turnstile.com",
			"google.com",
			"*.google.com",
			"googleapis.com",
			"*.googleapis.com",
			"gstatic.com",
			"*.gstatic.com",
			"googleusercontent.com",
			"*.googleusercontent.com",
			"apple.com",
			"*.apple.com",
			"icloud.com",
			"idmsa.apple.com",
			"appleid.apple.com",
			"microsoftonline.com",
			"*.microsoftonline.com",
			"microsoft.com",
			"*.microsoft.com",
			"live.com",
			"*.live.com",
			"github.com",
			"*.github.com",
			"stripe.com",
			"*.stripe.com",
			"supabase.co",
			"*.supabase.co"
		]
	}
}
