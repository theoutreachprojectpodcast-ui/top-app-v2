# Copy to keystore.properties (gitignored) after generating your upload keystore.
# See ANDROID_PLAY_STORE_RELEASE_CHECKLIST.md §2.
#
# storeFile is relative to web/android/app/ (Gradle app module)
storeFile=../keystores/top-upload.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=top-upload
keyPassword=YOUR_KEY_PASSWORD
