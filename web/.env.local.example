# --- Supabase (browser + server) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: required for WorkOS profile sync, onboarding, avatar upload, saved-orgs API, Stripe webhooks,
# enrichment writes, and public catalog API routes (/api/sponsors/catalog, /api/trusted/catalog, /api/directory/search)
# that prefer this key so localhost shows the same enriched logos/headers as production when anon RLS is stricter.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo/local Supabase sync uses this table with the anon key (default top_app_user_profiles).
# WorkOS cloud profiles are stored via service role in PROFILE_TABLE (server-only), default:
# - Vercel Preview: top_qa_profiles
# - Other envs: torp_profiles
# PROFILE_TABLE=top_qa_profiles
# Legacy/public override (avoid in deployment): NEXT_PUBLIC_PROFILE_TABLE=top_app_user_profiles

# Optional saved-org table (default top_app_saved_org_eins)
# NEXT_PUBLIC_SAVED_ORG_TABLE=top_app_saved_org_eins

# Local-only rich data seed (scripts/seed-local-dev-data.mjs). Requires TOP_LOCAL_DATA_SEED=1 and NODE_ENV != production.
# All seeded torp_profiles + community author_id values use WorkOS user ids (user_…) from the WorkOS dashboard.
# TOP_LOCAL_DATA_SEED=1
# TOP_SEED_COMMUNITY_AUTHOR_WORKOS_USER_IDS=user_01ABC,user_02DEF,user_03GHI
# One test user is OK: repeat the same id three times, or use a single id (script pads to 3 slots).
# TOP_SEED_TARGET_WORKOS_USER_ID=user_01ABC
# TOP_SEED_TARGET_EMAIL=you@yourdomain.com
# TOP_SEED_SPONSOR_APPLICANT_WORKOS_USER_ID=user_01ABC
# Demo-only client flows (local fallback auth/payments). Defaults OFF in production.
# Set to 1 only for local testing.
# NEXT_PUBLIC_ENABLE_DEMO_FLOWS=0

# Vercel QA (Preview, branch QA): use https://qa-the-outreach-project.vercel.app for APP_BASE_URL,
# NEXT_PUBLIC_APP_URL, and register https://qa-the-outreach-project.vercel.app/callback in WorkOS.
# See web/docs/TOP_v0.4_RELEASE_WORKFLOW.md.

# Canonical app origin (WorkOS callback, fallbacks). Falls back to NEXT_PUBLIC_APP_URL.
# For `pnpm dev` (port 3000) use 3000 here; for `pnpm dev:alt` (port 3001) use 3001.
# Membership/podcast Stripe success/cancel URLs also derive the host from the incoming API request,
# so checkout returns to the same port you are using even if this is still set to the other port.
APP_BASE_URL=http://localhost:3000

# Public site URL (browser + fallback when APP_BASE_URL unset)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- WorkOS AuthKit ---
# CLI: from web/ run `pnpm workos` (requires Node >= 20.20). See docs/WORKOS_CLI.md
# https://dashboard.workos.com — Staging vs Production are separate environments (top switcher in the dashboard).
#
# Local / Preview (QA): Staging keys are fine — typically sk_test_… + matching client_… from the Staging environment.
# Vercel Production: use Production keys only — sk_live_… + Production client_… (build fails if sk_test_ is set; see validate-production-env.mjs).
# Register Redirect URIs in the same WorkOS environment as the keys you use (e.g. localhost under Staging, apex domain under Production).
# Examples: http://localhost:3000/callback (pnpm dev), http://localhost:3001/callback (pnpm dev:alt)
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=generate-at-least-32-characters-securely
# Redirect URI registered in WorkOS (AuthKit uses this env var; not WORKOS_REDIRECT_URI).
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Production: same session on apex + www + admin (no leading dot). Must match WorkOS AuthKit docs.
# WORKOS_COOKIE_DOMAIN=theoutreachproject.app
# Optional alias if you cannot set WORKOS_COOKIE_DOMAIN for non-WorkOS cookies only:
# TOP_SHARED_COOKIE_DOMAIN=theoutreachproject.app
# Admin CMS hostname (single deployment; proxy rewrites this host to /admin). Local dev: leave unset.
# NEXT_PUBLIC_ADMIN_URL=https://admin.theoutreachproject.app
# The Outreach Project — WorkOS organization id (org_…). Required for org-exclusive sign-in in QA/production.
# WORKOS_ORGANIZATION_ID=org_...
# Sliding idle timeout (ms) before automatic /sign-out; default 24h. Use 0 to disable.
# TOP_SESSION_IDLE_MS=86400000

# --- Podcast / YouTube (server only; never NEXT_PUBLIC_*) ---
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_ID=UC...
# PODCAST_CACHE_TTL=900
# PODCAST_MIN_FULL_EPISODE_SECONDS=420
# Fetch YouTube captions into podcast_episodes.transcript_text during cached landing rebuild (default 1). Set 0 to skip.
# Requires web/supabase/podcast_episodes_transcript.sql applied.
# PODCAST_LANDING_TRANSCRIPT_FETCH=1

# --- Stripe (recurring: Support $1.99/mo, Pro $5.99/mo; optional sponsor subscription tier) ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SUPPORT_MONTHLY=price_...
# Prefer STRIPE_PRICE_PRO_MONTHLY for Pro; legacy STRIPE_PRICE_MEMBER_MONTHLY still works if PRO is unset.
STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_MEMBER_MONTHLY=price_...
STRIPE_PRICE_SPONSOR_MONTHLY=price_...

# One-time Stripe Prices for Podcast “Sponsor the show” tiers (Checkout mode=payment). All three required for live podcast checkout.
# STRIPE_PRICE_PODCAST_SPONSOR_COMMUNITY=price_...
# STRIPE_PRICE_PODCAST_SPONSOR_IMPACT=price_...
# STRIPE_PRICE_PODCAST_SPONSOR_FOUNDATIONAL=price_...

# Full URL users return to after Stripe Customer Portal (optional; default is APP_BASE_URL/profile)
# STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3001/profile

# --- Moderator tools (Community + Sponsors enrichment on http://localhost:3001) ---
# Comma-separated: must match the email you use when signing in with WorkOS locally.
COMMUNITY_MODERATOR_EMAILS=you@example.com
# Optional: WorkOS user IDs instead of or in addition to emails
# COMMUNITY_MODERATOR_WORKOS_USER_IDS=user_01...
# Optional buckets (defaults: org-header-images, sponsor-logos)
# ORG_HEADER_IMAGE_BUCKET=org-header-images
# SPONSOR_LOGO_BUCKET=sponsor-logos

# Platform admin (`/admin` console). Comma-separated emails — grants access even before `torp_profiles.platform_role` is set to admin in SQL.
# Prefer DB role `admin` for production; use this for bootstrap or break-glass access.
# PLATFORM_ADMIN_EMAILS=andy@valentelabs.com

# --- Existing optional keys (nonprofit enrich, etc.) ---
# SUPABASE_SERVICE_ROLE_KEY already listed above
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
# NEXT_PUBLIC_TRUSTED_RESOURCES_TABLE=trusted_resources
# NEXT_PUBLIC_BRAND_LOGO_PATH=/brand-logo-full.png
