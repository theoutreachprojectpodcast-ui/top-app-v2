# --- Supabase (browser + server) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: required for WorkOS profile sync, onboarding, avatar upload, saved-orgs API, Stripe webhooks,
# and all enrichment routes that write to the DB or Supabase Storage (org header images, sponsor logos, sponsor meta enrich).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo/local Supabase sync uses this table with the anon key (default top_app_user_profiles).
# WorkOS cloud profiles are stored in torp_profiles via the service role only — do not point the anon client at torp_profiles.
# NEXT_PUBLIC_PROFILE_TABLE=top_app_user_profiles

# Optional saved-org table (default top_app_saved_org_eins)
# NEXT_PUBLIC_SAVED_ORG_TABLE=top_app_saved_org_eins

# Canonical app origin (Stripe redirects, WorkOS callback). Falls back to NEXT_PUBLIC_APP_URL.
APP_BASE_URL=http://localhost:3000

# Public site URL (browser + fallback when APP_BASE_URL unset)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- WorkOS AuthKit ---
# CLI: from web/ run `pnpm workos` (requires Node >= 20.20). See docs/WORKOS_CLI.md
# https://dashboard.workos.com — Redirect URI must match exactly (e.g. http://localhost:3000/callback)
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=generate-at-least-32-characters-securely
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Stripe (recurring: Support $1.99/mo, Pro $5.99/mo; optional sponsor subscription tier) ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SUPPORT_MONTHLY=price_...
# Prefer STRIPE_PRICE_PRO_MONTHLY for Pro; legacy STRIPE_PRICE_MEMBER_MONTHLY still works if PRO is unset.
STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_MEMBER_MONTHLY=price_...
STRIPE_PRICE_SPONSOR_MONTHLY=price_...

# One-time Stripe Prices for Podcast “Sponsor the show” tiers (Checkout mode=payment). All three required for live podcast checkout.
# STRIPE_PRICE_PODCAST_SPONSOR_COMMUNITY=price_...
# STRIPE_PRICE_PODCAST_SPONSOR_IMPACT=price_...
# STRIPE_PRICE_PODCAST_SPONSOR_FOUNDATIONAL=price_...

# Full URL users return to after Stripe Customer Portal (optional; default is APP_BASE_URL/profile)
# STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3000/profile

# --- Moderator tools (Community + Sponsors enrichment on http://localhost:3000) ---
# Comma-separated: must match the email you use when signing in with WorkOS locally.
COMMUNITY_MODERATOR_EMAILS=you@example.com
# Optional: WorkOS user IDs instead of or in addition to emails
# COMMUNITY_MODERATOR_WORKOS_USER_IDS=user_01...
# Optional buckets (defaults: org-header-images, sponsor-logos)
# ORG_HEADER_IMAGE_BUCKET=org-header-images
# SPONSOR_LOGO_BUCKET=sponsor-logos

# --- Existing optional keys (nonprofit enrich, etc.) ---
# SUPABASE_SERVICE_ROLE_KEY already listed above
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
# NEXT_PUBLIC_PROVEN_ALLIES_TABLE=proven_allies
# NEXT_PUBLIC_BRAND_LOGO_PATH=/brand-logo-full.png
