NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: required to persist nonprofit_directory_enrichment from POST /api/nonprofit/enrich
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Google Custom Search JSON API — gap-fill short descriptions after verified site extraction
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Optional: Supabase table name for the public Trusted Resources catalog (default: proven_allies)
# NEXT_PUBLIC_PROVEN_ALLIES_TABLE=proven_allies

# Optional: override header logo (path under /public after asset sync)
# NEXT_PUBLIC_BRAND_LOGO_PATH=/brand-logo-full.png
