# Core URLs
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WorkOS AuthKit
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=generate-at-least-32-characters
# AuthKit reads this (must match a Redirect URI in WorkOS). Some teams also document the same URL as WORKOS_REDIRECT_URI in Vercel notes — the app does not read WORKOS_REDIRECT_URI.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# WORKOS_COOKIE_DOMAIN=theoutreachproject.app
# NEXT_PUBLIC_ADMIN_URL=https://admin.theoutreachproject.app
# The Outreach Project org in WorkOS (User Management → Organizations). Pins sign-in/up to this org and rejects other-org tokens.
# WORKOS_ORGANIZATION_ID=org_...
# Idle sign-out: milliseconds without requests before redirect to /sign-out (default 86400000 = 24h). Set 0 to disable sliding idle.
# TOP_SESSION_IDLE_MS=86400000

# Optional role bootstrap
# PLATFORM_ADMIN_EMAILS=admin@yourdomain.com
# COMMUNITY_MODERATOR_EMAILS=moderator@yourdomain.com

# Outbound email (Resend) — sponsor applications, podcast guest apply, admin invoices
# ADMIN_EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_...
# ADMIN_EMAIL_FROM=The Outreach Project <notifications@your-verified-domain.com>
# APPLICATION_NOTIFY_RECIPIENTS=jmelching1@gmail.com,hodge5403@gmail.com,andy@volentelabs.com
# Legacy aliases (optional): MISSION_PARTNER_APPLICATION_RECIPIENTS, PODCAST_GUEST_APPLICATION_RECIPIENTS

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ACCESS_YEARLY=price_...
STRIPE_PRICE_SUPPORT_MONTHLY=price_...
STRIPE_PRICE_MEMBER_MONTHLY=price_...

# Podcast / YouTube pipeline (server-only keys — never NEXT_PUBLIC_*)
# Google Cloud → APIs & Services → enable YouTube Data API v3 → API key (restrict to that API).
# YOUTUBE_API_KEY=            (aliases: YOUTUBE_DATA_API_KEY, GOOGLE_API_KEY)
# YOUTUBE_CHANNEL_ID=UC...   (optional if channel discovery from @ handle works)
# Full-episodes playlist for “Last 10” on /podcasts (default matches Outreach Project list):
# YOUTUBE_FULL_EPISODES_PLAYLIST_ID=PLxrmox4oWE7d-ZmMCc2lNkk4nXE8zKcKP
# PODCAST_CACHE_TTL=900       (seconds for public landing cache; default 900)
# PODCAST_MIN_FULL_EPISODE_SECONDS=420

# Demo fallback (localhost only; keep disabled in QA/prod)
NEXT_PUBLIC_ENABLE_DEMO_FLOWS=0
